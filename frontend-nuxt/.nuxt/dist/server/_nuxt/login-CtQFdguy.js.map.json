;AAAA,YAAA;+BAHZ,CAMUC,IAAAH,QAAAC,UAAAG,cAAA;;;;;oCAFT,UAED;AAAA,kBAAA;AAAA;;;;;;;cArCS,MAAA,sBAAXC,YAEM,OAAA;AAAA;gBAFY,OAAM;AAAA,cAAA,mBACnB,MAAA,KAAK,GAAA,CAAA;cAGC,QAAA,sBAAXA,YAEM,OAAA;AAAA;gBAFc,OAAM;AAAA,cAAA,mBACrB,QAAA,KAAO,GAAA,CAAA;cAGZH,YA8BO,QAAA;AAAA,gBA9BA,wBAAgB,cAAY,CAAA,SAAA,CAAA;AAAA,gBAAE,OAAM;AAAA,cAAA;gBACzCA,YASa,uBAAA;AAAA,kBATD,OAAM;AAAA,kBAAS,MAAK;AAAA,kBAAQ,UAAA;AAAA,gBAAA;mCACtC,MAOE;AAAA,oBAPFA,YAOE,mBAAA;AAAA,sBANA,IAAG;AAAA,kCACM,MAAA;AAAA,yDAAA,MAAK,QAAA;AAAA,sBACd,MAAK;AAAA,sBACL,aAAY;AAAA,sBACZ,UAAA;AAAA,sBACC,UAAU,QAAA;AAAA,oBAAA;;;;gBAIfA,YASa,uBAAA;AAAA,kBATD,OAAM;AAAA,kBAAQ,MAAK;AAAA,kBAAW,UAAA;AAAA,gBAAA;mCACxC,MAOE;AAAA,oBAPFA,YAOE,mBAAA;AAAA,sBANA,IAAG;AAAA,kCACM,SAAA;AAAA,yDAAA,SAAQ,QAAA;AAAA,sBACjB,MAAK;AAAA,sBACL,aAAY;AAAA,sBACZ,UAAA;AAAA,sBACC,UAAU,QAAA;AAAA,oBAAA;;;;gBAIfA,YAMU,oBAAA;AAAA,kBALR,MAAK;AAAA,kBACL,OAAA;AAAA,kBACC,SAAS,QAAA;AAAA,gBAAA;mCACX,MAED;AAAA,oCAFC,UAED;AAAA,kBAAA;;;;;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_","_scopeId","_createBlock"],"sources":["../../../../pages/login.vue"],"sourcesContent":["<template>\n  <main class=\"min-h-screen flex items-center justify-center p-4\">\n    <div class=\"w-full max-w-md\">\n      <UCard>\n        <template #header>\n          <div class=\"text-center\">\n            <h1 class=\"text-3xl font-bold tracking-tight\">MEI Finance</h1>\n            <p class=\"text-sm text-gray-500 mt-1\">\n              Gerencie suas contas PJ e PF de forma inteligente\n            </p>\n          </div>\n        </template>\n\n        <div v-if=\"error\" class=\"mb-4 text-sm text-red-500 bg-red-50 dark:bg-red-950/20 p-2.5 rounded\">\n          {{ error }}\n        </div>\n\n        <div v-if=\"success\" class=\"mb-4 text-sm text-green-500 bg-green-50 dark:bg-green-950/20 p-2.5 rounded\">\n          {{ success }}\n        </div>\n\n        <form @submit.prevent=\"handleSubmit\" class=\"space-y-4\">\n          <UFormGroup label=\"E-mail\" name=\"email\" required>\n            <UInput\n              id=\"email\"\n              v-model=\"email\"\n              type=\"email\"\n              placeholder=\"Ex: carlos@email.com\"\n              required\n              :disabled=\"loading\"\n            />\n          </UFormGroup>\n\n          <UFormGroup label=\"Senha\" name=\"password\" required>\n            <UInput\n              id=\"password\"\n              v-model=\"password\"\n              type=\"password\"\n              placeholder=\"••••••••\"\n              required\n              :disabled=\"loading\"\n            />\n          </UFormGroup>\n\n          <UButton\n            type=\"submit\"\n            block\n            :loading=\"loading\"\n          >\n            Entrar\n          </UButton>\n        </form>\n\n        <template #footer>\n          <div class=\"text-center text-xs text-gray-500\">\n            Ainda não tem cadastro? \n            <NuxtLink to=\"/register\" class=\"text-primary hover:underline font-semibold\">\n              Criar conta\n            </NuxtLink>\n          </div>\n        </template>\n      </UCard>\n    </div>\n  </main>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref } from 'vue'\n\ndefinePageMeta({\n  layout: false\n})\n\nconst email = ref('')\nconst password = ref('')\nconst error = ref('')\nconst success = ref('')\nconst loading = ref(false)\n\nconst { login } = useAuth()\n\nconst handleSubmit = async () => {\n  error.value = ''\n  success.value = ''\n  loading.value = true\n\n  const result = await login(email.value, password.value)\n  if (result.success) {\n    success.value = 'Acesso concedido! Carregando painel...'\n    setTimeout(() => {\n      navigateTo('/dashboard')\n    }, 1500)\n  } else {\n    error.value = result.message || 'Erro ao tentar acessar. Tente novamente.'\n    loading.value = false\n  }\n}\n</script>\n"],"version":3}